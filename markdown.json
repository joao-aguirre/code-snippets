{
	// Place your snippets for markdown here. Each snippet is defined under a snippet name and has a prefix, body and 
	// description. The prefix is what is used to trigger the snippet and the body will be expanded and inserted. Possible variables are:
	// $1, $2 for tab stops, $0 for the final cursor position, and ${1:label}, ${2:another} for placeholders. Placeholders with the 
	// same ids are connected.
	// Example:
	// "Print to console": {
	// 	"prefix": "log",
	// 	"body": [
	// 		"console.log('$1');",
	// 		"$2"
	// 	],
	// 	"description": "Log output to console"
	// }
    "Insert ISO date": {
        "prefix": ["iso-date", "idate"],
        "body": [
            "${CURRENT_YEAR}-${CURRENT_MONTH}-${CURRENT_DATE}"
        ],
        "description": "Insert date in ISO format."
    },
    "Insert journal ISO date": {
        "prefix": ["journal-date", "jdate"],
        "body": [
            "### ${CURRENT_YEAR}-${CURRENT_MONTH}-${CURRENT_DATE}"
        ],
        "description": "Insert date in ISO format as a third level header for my journals."
    },
    "Work-Note Template": {
        "prefix": ["work-note", "wnote"],
        "body": [
            "# ${TM_FILENAME_BASE}\n",
            "$1\n",
            "## 🎯 Objective\n",
            "## 🔥 Important/Priority\n",
            "## ✅ To-Do\n",
            "## 🕥 Waiting For\n",
            "## 📝 Notes\n",
            "### 💡 Ideas\n",
            "### 🧮 Formulation\n",
            "### 📑 References\n",
            "### ❓ Questions\n",
            "## 📆 Journal\n",
            "### ${CURRENT_YEAR}-${CURRENT_MONTH}-${CURRENT_DATE}\n",
            "$2\n"
        ],
        "description": "Templete for my work-notes entries."
    },
    "Paper Review Template": {
        "prefix": ["paper-review", "rpaper"],
        "body": [
            "# ${TM_FILENAME_BASE}\n",
            "$1\n",
            "## 📝 Notes\n",
            "## ❓ Questions\n",
            "## 📑 References\n"
        ],
        "description": "Templete for my paper review entries."
    },
    "Marp Presentation Footer + 2 Columns": {
        "prefix": ["marp-footer-columns", "mfc"],
        "body": [
            "---\n",
            "marp: true\n",
            "theme: default\n",
            "headingDivider: 2\n",
            "paginate: true\n",
            "math: mathjax\n",
            "style: |\n",
            "    .columns {\n",
            "        display: grid;\n",
            "        grid-template-columns: repeat(2, minmax(0, 1fr));\n",
            "        gap: 1rem;\n",
            "    }\n",
            "footer: \"![height:1cm]($1)\"\n",
            "---\n\n",
            "# ${2:title}\n\n",
            "<!-- _paginate: false -->\n",
            "<!-- _footer: \"\" -->\n\n",
            "![bg contain left:33%](${3:side-background})\n\n",
            "<p style=\"text-align: center;\">${4:author}</p>\n\n",
            "---\n\n",
            "# ${5:slide-title}\n\n",
            "<div class=\"columns\">\n",
            "<div>\n",
            "- ${6:column-1-content}\n",
            "</div>\n",
            "<div>\n",
            "${7:column-2-content}\n",
            "</div>\n",
            "        ]\n\n",
            "\n"
        ]
    }
}