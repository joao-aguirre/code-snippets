{
    // Place your snippets for cmake here. Each snippet is defined under
    // a snippet name and has a prefix, body and description. The prefix
    // is what is used to trigger the snippet and the body will be
    // expanded and inserted. Possible variables are: $1, $2 for tab
    // stops, $0 for the final cursor position, and ${1:label},
    // ${2:another} for placeholders. Placeholders with the same ids are
    // connected.
    // Example:
    // "Print to console": {
    //  "prefix": "log",
    //  "body": [
    //      "console.log('$1');",
    //      "$2"
    //  ],
    //  "description": "Log output to console"
    // }
    "show compiler flags":
    {
        "prefix": "show-compiler-flags",
        "description": "Add commands to show compiler flags during configure.",
        "body": [
            "message(\"CMAKE_CXX_FLAGS_DEBUG flags are \\${CMAKE_CXX_FLAGS_DEBUG}\")",
            "message(\"CMAKE_CXX_FLAGS_RELWITHDEBINFO flags are \\${CMAKE_CXX_FLAGS_RELWITHDEBINFO}\")",
            "message(\"CMAKE_CXX_FLAGS_MINSIZEREL flags are \\${CMAKE_CXX_FLAGS_MINSIZEREL}\")",
            "message(\"CMAKE_CXX_FLAGS_RELEASE flags are \\${CMAKE_CXX_FLAGS_RELEASE}\")"
        ]
    },
    "show all CMake available variables":
    {
        "prefix": "show-variables",
        "description": "Show all defined (available) CMake variables and values.",
        "body": [
            "get_cmake_property(_variableNames VARIABLES)",
            "list (SORT _variableNames)",
            "message(STATUS \"... --- CMake available variables ---\")",
            "foreach (_variableName \\${_variableNames})",
            "    message(STATUS \"... \\${_variableName}=${\\${_variableName}}\")",
            "endforeach()"
        ]
    },
    "show all CMake variables function":
    {
        "prefix": "show-variables-function",
        "description": "Defines a function that shows all defined (or selecte via regexp) CMake variables and values.",
        "body": [
            "function(dump_cmake_variables)",
            "    get_cmake_property(_variableNames VARIABLES)",
            "    list (SORT _variableNames)",
            "    foreach (_variableName \\${_variableNames})",
            "        if (ARGV0)",
            "            unset(MATCHED)",
            "            string(REGEX MATCH \\${ARGV0} MATCHED \\${_variableName})",
            "            if (NOT MATCHED)",
            "                continue()",
            "            endif()",
            "        endif()",
            "        message(STATUS \"\\${_variableName}=\\${\\${_variableName}}\")",
            "    endforeach()",
            "endfunction()"
        ]
    }
}
